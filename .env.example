# Required — shared secret with api-oq-agile-athletes Node API
FOOD_VISION_API_KEY=change-me-to-a-long-random-secret

# Server
PORT=8000
LOG_LEVEL=info

# Inference backend: onnx (recommended) or torch (legacy, needs Python 3.11–3.13)
INFERENCE_BACKEND=onnx
MODEL_ID=onnx-community/swin-finetuned-food101-ONNX
ONNX_MODEL_FILE=onnx/model.onnx

# Legacy PyTorch settings (only if INFERENCE_BACKEND=torch)
# MODEL_ID=nateraw/food

TOP_K=5
MAX_BASE64_CHARS=900000
INFERENCE_TIMEOUT_SEC=55

# OpenAPI docs (set false in production)
ENABLE_DOCS=true

# Hugging Face model cache (useful on Render ephemeral disk)
# HF_HOME=/opt/render/.cache/huggingface
